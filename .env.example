# API (apps/api)
# Docker Compose (postgres en 5433). En macOS use 127.0.0.1 si `localhost` no conecta:
# DATABASE_URL="postgresql://meta:meta@127.0.0.1:5433/meta_contabilidad"
# Postgres nativo (ajusta usuario/host):
DATABASE_URL="postgresql://TU_USUARIO@localhost:5432/meta_contabilidad"
PORT=8787
# Opcional: al iniciar la API, sincronizar dólar/UF desde el SII (solo dev; requiere red).
# AUTO_SYNC_SII_ON_STARTUP=true

# Stub admin header for MVP (no real auth yet)
ADMIN_API_KEY="dev-admin-key-change-me"

# Web (apps/web) — Omitir VITE_API_URL para usar el proxy de Vite (/api → 8787).
# VITE_API_URL="http://localhost:8787"
VITE_ADMIN_API_KEY="dev-admin-key-change-me"
